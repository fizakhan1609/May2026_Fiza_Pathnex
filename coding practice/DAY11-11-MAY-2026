## Ansible - Install Helm on server 
- name/;/ Install Hel
  hosts: all
  become:yes
  tasks:
    -name: Download helm 
     get_url:
       url: https://get,helm.sh/helm-v3,7.0-linux-amd64,tar,gz
       dest: /tmo/helm,tar,gz

    - name: Extarct Helm
      unarchive:
       scr: /tmp/hem,ter,gz
       dest: /usr/local/bin/
       remote_src: yes

    - name: Set Hel, binary permissions
      file:
         path /usr/loccal/bin/helm
        mode: '0755'
