## Ansible --- Deploy a web Application to Multipe Hosts
- name: Deploy web applicatiion to multiple hosts
  hsts: all
  become: yes
  tasks:
    - name: copy web app files
      copy: 
        src: /path/to /web/app/
       dest: /var/www/html/
    - name: Start web app service
      service:
        name: apache 2 
        stat: started
        enabled: yes
