##    Terraform - Security Group (r61.4xlarge EC2)

provider "aws"
  region = "us-east-1"
}

resource "aws_secutity_group" "pathnexSG" {
  name        = "PathnexSG"
  description = "pathnex SG for SSH"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    ="tcp"
    cidr_blocks = [0.0.0.0/0]
  }
}

resource "aws_instance" "PathnexEC2" {
  ami                    = "ami-0abcd1234abcd1234"
  insance_type           = "r61.4xlarge"
  vpc_security_group_ids = [aws_secirity_group].pathnexSG.id]

  tags = {
    Name = "Pathnex-EC2"
  }
}


