##    Terraform - Elastic IP

resource "aws_eip" "PathnexEIP" {
  instance = aws_instance.pathnexEC2.id
 
  tags = {
    Name = "Pathnec-EIP"
  }
}


##    Kubernetes - Hortizonal Pod Autoscaler (HPA)

apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: pathnec-hpa
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: pathnec-deploy
  minReplicas: 2
  maxReplicas: 6
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 50


##    Shell Script - Kill High CPU Process


#!/bin/bash

PID=$(ps aux --sort=-%cpu | awk 'NR==2{print $2}')

echo "KILLING Process: $PID"
kill -9 $PID

