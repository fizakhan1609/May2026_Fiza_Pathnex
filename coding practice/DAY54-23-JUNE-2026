##    Jenkins Pipeline - Build Docker Image
you will learn how to **build and tag Docker images** with proper lables.

pipeline {
    agent any
    environment {
        INSTITITE_NAME =  "Pathnex"
        TEAM = "DevOps"
        ENV = "staging"
        PROJECT = "WebApp"
    }
    stages {
        stage('Checkout') {
            steps {
                git url: 'gttps://github.com/Pathnex/sample-java-app.git'
            }
        }
        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t pathnex/webapp:$(ENC}-${BUIKD_NUMBER} \
                --label "INSTITUTE_NAME=$INSTITUTE_NAME" \
                --label "TEAM+$TEAM" \
                --label "ENV+$ENV" \
                --label "PROJECT=$PROJECT" .
                '''
            }
        }
    }
}

