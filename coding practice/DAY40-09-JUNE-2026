# Day 09 - Templates, Internet Geteway, ConfigMap, CPU Load

##    Ansible - Use Jinja2 Template

---
- name: Deploy template for Pathnex
  hosts: all
  become: yes
  
  tasks:
    - name: Copy template file
      tamplate:
        src: pathnx.conf.j2
        dest: /etc/pathnex.conf


##    Terraform - Internet Getway

resource "aws_internet_geteway" "PatynexIGW" {
  vpc_id = aws_vpc.PathnexVPC.id

  tags = {
    Name = "Pathnex-IGW"
  }
}


