##    Ansible - Install & Enable Nginx


---
- name: Install and start Nginx on pathnex
  hosts: all
  become: yes

  tasks: 
    - name: Install nginx
      yum:
        name: nginx
        stage: present

    - name: Enable nginx
      srvice:

        name: nginc
        state: started
        enabled: yes


